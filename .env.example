# Required for AI chat and project explanations
GEMINI_API_KEY="your-gemini-api-key"

# Gmail SMTP (Google App Password — not your account password)
EMAIL_USER="your.email@gmail.com"
EMAIL_PASS="your_gmail_app_password"

# Server
PORT=3000
NODE_ENV=production

# Optional: MongoDB for contact backup storage (not required for email delivery)
MONGO_URI="your-mongodb-connection-string"

# Optional: public site URL for metadata
APP_URL="https://priyankchavda.in"
