# =============================================================================
# FRONTEND (Vercel / local Vite) — copy to .env for local dev
# =============================================================================
VITE_API_URL=http://localhost:8080

# Production (set in Vercel dashboard):
# VITE_API_URL=https://api.priyankchavda.info

# =============================================================================
# BACKEND (Render / local API) — copy to .env for API server
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_gmail_app_password

PORT=8080
NODE_ENV=production

# Optional: comma-separated extra CORS origins
# CORS_ORIGINS=https://priyankchavda.info,https://www.priyankchavda.info

# Optional: MongoDB contact backup (email works without this)
# MONGO_URI=your-mongodb-connection-string
