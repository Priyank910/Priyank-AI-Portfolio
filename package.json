{
  "name": "priyank-chavda-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:server",
    "dev:client": "vite",
    "dev:server": "node server.js",
    "build": "vite build",
    "build:server": "node scripts/copy-build-data.js && esbuild server.js --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "node -e \"const fs=require('fs');['dist'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\"",
    "lint": "echo 'No linter configured'"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.546.0",
    "mongoose": "^9.6.2",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.8",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.1",
    "validator": "^13.15.35",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
